# Optional project-local uv cache
.uv-cache/

# Committed test suite and fixtures. These negations must stay last: the broad
# `*.parquet` / `*.jsonl` rules above would otherwise swallow the golden files.
!tests/
!tests/**
!experiment-cli/data/*.parquet
!experiment-cli/data/*.jsonl
# ...but the negations above also re-include the compiled cache; keep it out.
tests/**/__pycache__/
