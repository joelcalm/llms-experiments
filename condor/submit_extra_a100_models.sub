# Additional A100 exploratory models: one job per model.
universe = vanilla
initialdir = $ENV(RUN_ROOT)
executable = $ENV(RUN_ROOT)/code/artemisa/run_matrix_worker.sh

request_gpus = 1
request_cpus = 16
request_memory = 128GB
request_disk = 160GB
requirements = regexp("A100", TARGET.Gpus_DeviceName)
priority = -100

should_transfer_files = NO
stream_output = True
stream_error = True
getenv = True
environment = "RUN_ROOT=$ENV(RUN_ROOT) MODEL_SLUG=$(model_slug) MODEL_ID=$(model_id) GPU_MEMORY_UTILIZATION=$(gpu_memory_utilization) MAX_NUM_SEQS=$(max_num_seqs) MM_ENCODER_ATTN_BACKEND=$(mm_encoder_attn_backend) ATTN_BACKEND=$(attn_backend) HF_HOME=/lustre/ific.uv.es/ml/iiia021/hf_cache SHARED_CACHE_ROOT=/lustre/ific.uv.es/ml/iiia021/shared_cache"

output = $ENV(RUN_ROOT)/logs/$(model_slug).$(Cluster).$(Process).out
error = $ENV(RUN_ROOT)/logs/$(model_slug).$(Cluster).$(Process).err
log = $ENV(RUN_ROOT)/logs/$(model_slug).$(Cluster).$(Process).log

+JobBatchName = "llms-experiment-cli-extra-a100-models"
periodic_remove = (JobStatus == 2 && RemoteWallClockTime > 172800)

queue model_slug,model_id,gpu_memory_utilization,max_num_seqs,mm_encoder_attn_backend,attn_backend from (
  openai_gpt_oss_20b openai/gpt-oss-20b 0.85 64 NONE TRITON_ATTN
  mistralai_ministral_3_14b mistralai/Ministral-3-14B-Instruct-2512 0.85 64 NONE TRITON_ATTN
)
