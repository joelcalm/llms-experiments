universe = vanilla
initialdir = $ENV(RUN_ROOT)
executable = $ENV(RUN_ROOT)/code/condor/run_matrix_worker.sh

request_gpus = 1
request_cpus = 16
request_memory = 128GB
request_disk = 160GB
requirements = regexp("H100", TARGET.Gpus_DeviceName)
priority = -100

should_transfer_files = NO
stream_output = True
stream_error = True
getenv = True
# Restart under the corrected code/config, but restricted to the datasets
# that actually need redoing (MFTC/MFRC label fix, ProtoEthos slice=core
# fix). valueeval already completed correctly under the old config and is
# deliberately left out of --datasets so run()'s resume/invalidation logic
# never touches it.
environment = "RUN_ROOT=$ENV(RUN_ROOT) MODEL_SLUG=google_gemma_4_31b_it MODEL_ID=google/gemma-4-31B-it GPU_MEMORY_UTILIZATION=0.90 MAX_NUM_SEQS=128 DATASETS=mftc,mfrc,protoethos_mft,protoethos_shvt"

output = $ENV(RUN_ROOT)/logs/google_gemma_4_31b_it.$(Cluster).$(Process).out
error = $ENV(RUN_ROOT)/logs/google_gemma_4_31b_it.$(Cluster).$(Process).err
log = $ENV(RUN_ROOT)/logs/google_gemma_4_31b_it.$(Cluster).$(Process).log

+JobBatchName = "llms-experiment-cli-full-matrix"
periodic_remove = (JobStatus == 2 && RemoteWallClockTime > 172800)

queue 1
