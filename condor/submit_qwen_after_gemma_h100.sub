universe = vanilla
initialdir = $ENV(RUN_ROOT)
executable = $ENV(RUN_ROOT)/code/condor/run_matrix_worker.sh

request_gpus = 1
request_cpus = 16
request_memory = 128GB
request_disk = 160GB
requirements = regexp("H100", TARGET.Gpus_DeviceName)
# Gemma's final run remains ahead of this queued Qwen run.
priority = -200

should_transfer_files = NO
stream_output = True
stream_error = True
getenv = True
environment = "RUN_ROOT=$ENV(RUN_ROOT) MODEL_SLUG=qwen_qwen3_6_35b_a3b MODEL_ID=Qwen/Qwen3.6-35B-A3B GPU_MEMORY_UTILIZATION=0.92 MAX_NUM_SEQS=128 MM_ENCODER_ATTN_BACKEND=TORCH_SDPA"

output = $ENV(RUN_ROOT)/logs/qwen_qwen3_6_35b_a3b.$(Cluster).$(Process).out
error = $ENV(RUN_ROOT)/logs/qwen_qwen3_6_35b_a3b.$(Cluster).$(Process).err
log = $ENV(RUN_ROOT)/logs/qwen_qwen3_6_35b_a3b.$(Cluster).$(Process).log

+JobBatchName = "llms-experiment-cli-qwen-after-gemma"
periodic_remove = (JobStatus == 2 && RemoteWallClockTime > 172800)

queue 1
