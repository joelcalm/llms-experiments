{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "InputConfig": {
      "additionalProperties": true,
      "properties": {
        "format": {"type": "string"},
        "id_column": {"type": "string"},
        "path": {"type": "string"},
        "text_column": {"type": "string"}
      },
      "required": ["path", "format", "id_column", "text_column"],
      "type": "object"
    },
    "DatasetConfig": {
      "additionalProperties": true,
      "properties": {
        "id": {"minLength": 1, "type": "string"},
        "input": {"$ref": "#/$defs/InputConfig"}
      },
      "required": ["id", "input"],
      "type": "object"
    },
    "ModelConfig": {
      "additionalProperties": true,
      "properties": {
        "backend": {"enum": ["local_vllm", "openai_compatible", "fake"], "type": "string"},
        "name": {"minLength": 1, "type": "string"}
      },
      "required": ["name", "backend"],
      "type": "object"
    },
    "RunConfig": {
      "additionalProperties": true,
      "properties": {"id": {"minLength": 1, "type": "string"}},
      "required": ["id"],
      "type": "object"
    },
    "OutputConfig": {
      "additionalProperties": true,
      "properties": {"directory": {"type": "string"}},
      "required": ["directory"],
      "type": "object"
    },
    "VariantConfig": {
      "additionalProperties": true,
      "properties": {
        "id": {"minLength": 1, "type": "string"},
        "prompts": {"items": {"type": "string"}, "minItems": 1, "type": "array"},
        "request_mode": {"enum": ["generate", "candidate_logprobs"], "type": "string"},
        "result_type": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null}
      },
      "required": ["id", "request_mode", "prompts"],
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Top-level run contract for one input or a dataset matrix.",
  "properties": {
    "datasets": {
      "anyOf": [{"items": {"$ref": "#/$defs/DatasetConfig"}, "type": "array"}, {"type": "null"}],
      "default": null
    },
    "input": {"anyOf": [{"$ref": "#/$defs/InputConfig"}, {"type": "null"}], "default": null},
    "model": {"$ref": "#/$defs/ModelConfig"},
    "output": {"$ref": "#/$defs/OutputConfig"},
    "run": {"$ref": "#/$defs/RunConfig"},
    "variants": {"items": {"$ref": "#/$defs/VariantConfig"}, "minItems": 1, "type": "array"}
  },
  "required": ["run", "model", "variants", "output"],
  "title": "ExperimentConfig",
  "type": "object"
}
